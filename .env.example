# ===========================================
# FABOT Podcast Studio - Configuração
# ===========================================
# COPIE este arquivo para .env e preencha os valores
# O .env NÃO deve ser commitado (já está no .gitignore)
# ===========================================

# Modo debug (True/False)
DEBUG=true

# Redis
REDIS_URL=redis://localhost:6379

# Banco de dados
DATABASE_PATH=./backend/db/fabot.db

# Pastas
OUTPUT_DIR=./data/output
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_MB=50

# LLM Padrão (groq, gemini-2.5-flash, glm, ollama)
DEFAULT_LLM_MODE=gemini-2.5-flash

# ===========================================
# API KEYS - OBTENHA EM:
# ===========================================

# Groq: https://console.groq.com/keys
GROQ_API_KEY=sua_chave_groq_aqui

# Google AI (Gemini): https://aistudio.google.com/app/apikey
GEMINI_API_KEY=sua_chave_gemini_aqui

# Zhipu AI (GLM): https://open.bigmodel.cn/
GLM_API_KEY=sua_chave_glm_aqui

# Ollama (local)
OLLAMA_URL=http://localhost:11434

# Kokoro TTS (local)
KOKORO_URL=http://localhost:8880

# ===========================================
# LOGS
# ===========================================
LOG_LEVEL=INFO
