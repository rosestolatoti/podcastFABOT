# FABOT Podcast Studio - Variáveis de Ambiente
# Copie este arquivo para .env e preencha com suas chaves

# API Keys (OBRIGATÓRIAS)
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
GLM_API_KEY=your_glm_api_key_here

# URLs
OLLAMA_URL=http://localhost:11434
KOKORO_URL=http://localhost:8880
REDIS_URL=redis://localhost:6379

# Frontend API URL (para produção)
VITE_API_URL=http://localhost:8000

# Paths
DATABASE_PATH=backend/db/fabot.db
OUTPUT_DIR=data/output
UPLOAD_DIR=data/uploads

# Sistema
DEBUG=true
DEFAULT_LLM_MODE=glm
MAX_UPLOAD_MB=50
LOG_LEVEL=INFO
